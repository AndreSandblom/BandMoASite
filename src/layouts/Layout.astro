---
import "../styles/global.css";
const { title = "MoA- Marcus & André", isHeroPage = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}about/`, label: "Om oss" },
  { href: `${base}offers/`, label: "Tjänster" },
  { href: `${base}media/`, label: "Musik/Media" },
  { href: `${base}contact/`, label: "Kontakta oss" },
];

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);

const isActive = (href: string) => currentPath === normalizePath(href);
---

<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎸</text></svg>">
    <title>{title}</title>
  </head>

  <body class="bg-gray-200 text-gray-900 font-sans flex flex-col min-h-screen">
    <header class="absolute top-0 left-0 w-full z-20 shadow-md text-amber-100">
      <div class="container mx-auto px-4 py-4 flex justify-between items-center relative">
        <a
          href={`${base}`}
          class="text-amber-100 hover:text-amber-300 text-xl md:text-3xl font-semibold tracking-wide font-playfair"
        >
          M&A - Marcus & André
        </a>

        <button id="menu-toggle" class="md:hidden text-amber-100 text-3xl">
          ☰
        </button>

        <nav
          id="mobile-menu"
          class="md:flex md:flex-row items-center gap-6 md:gap-10 text-sm font-medium uppercase tracking-wide absolute md:static top-full left-0 w-full md:w-auto bg-black/40 md:bg-transparent backdrop-blur-md md:backdrop-blur-none p-6 md:p-0"
        >
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`nav-link ${isActive(item.href) ? "active-nav" : ""}`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="w-full border-b border-white/20"></div>
    </header>

    <main class={isHeroPage ? "w-full flex-1 p-0 m-0" : "container mx-auto px-4 pt-32 flex-grow"}>
      <slot />
    </main>

    <footer class="relative z-30 mt-auto bg-amber-100 text-black italic text-center p-3">
      <div class="container mx-auto flex flex-col items-center justify-between gap-3 px-4 py-2 md:flex-row">
        <p>© {new Date().getFullYear()} M&O - Marcus & André</p>

        <nav class="flex flex-wrap items-center justify-center gap-4 text-sm">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`transition hover:text-amber-700 ${isActive(item.href) ? "font-semibold" : ""}`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </footer>

    <script>
      const button = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");

      if (button && menu) {
        button.addEventListener("click", () => {
          menu.classList.toggle("open");
        });
      }
    </script>
  </body>
</html>
