---
import "../styles/global.css";
const { title = "MoA- Marcus & André",isHeroPage = false, } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-200 text-gray-900 font-sans flex flex-col min-h-screen">
		<header class="absolute top-0 left-0 w-full z-20 shadow-md text-amber-100">
			<div class="container mx-auto px-4 py-4 flex justify-between items-center relative">
				<a href={`${base}`} class="text-amber-100 hover:text-amber-300 text-xl md:text-3xl font-semibold tracking-wide font-playfair">
					M&A - Marcus & André
				</a>
				<button 
					id="menu-toggle"
					class="md:hidden text-amber-100 text-3xl"
					>
					☰
				</button>
				<nav
					id="mobile-menu"
					class="hidden md:flex flex-col md:flex-row items-center gap-6 md:gap-8 lg:gap-12 text-sm font-medium uppercase tracking-wide absolute md:static top-full left-0 w-full md:w-auto bg-black/70 md:bg-transparent backdrop-blur md:backdrop-blur-none p-6 md:p-0"
					>
					<a 
						href={`${base}about/`} 
						class={`nav-link ${currentPath === "/about" ? "active-nav" : ""}`}
					>
						Om oss
					</a>
					<a 
						href={`${base}offers/`} 
						class={`nav-link ${currentPath === "/offers" ? "active-nav" : ""}`}
					>
						Tjänster
					</a>
					<a 
						href={`${base}media/`}
						class={`nav-link ${currentPath === "/media" ? "active-nav" : ""}`}
					>
						Musik/Media
					</a>
					<a 
						href={`${base}contact/`}
						class={`nav-link ${currentPath === "/contact" ? "active-nav" : ""}`}
					>
						Kontakta oss
					</a>
				</nav>
			</div>
			<div class="w-full border-b border-white/20"></div>
		</header>
		<main class={isHeroPage ? "p-0 m-0" : "container mx-auto px-4 pt-32 flex-grow"}>
			<slot />
		</main>
		<footer class="bg-amber-100 text-black italic text-center p-3">
			© {new Date().getFullYear()} M&O - Marcus & André
		</footer>
		<script>
		const button = document.getElementById("menu-toggle");
		const menu = document.getElementById("mobile-menu");

		button.addEventListener("click", () => {
		menu.classList.toggle("hidden");
		});
		</script>
	</body>
</html>
