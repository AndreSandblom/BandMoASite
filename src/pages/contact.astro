---
import Layout from "../layouts/Layout.astro"
const base = import.meta.env.BASE_URL;
---

<Layout title="Kontakt | MoA - Marcus & André" isHeroPage={true}>

  <section class="relative min-h-screen flex flex-col items-center justify-center text-center text-white overflow-hidden py-24">

    <img 
      src={`${base}images/background_home_page_playing_guitar.jpg`}
      class="absolute inset-0 w-full h-full object-cover opacity-40"
    />

    <div class="absolute inset-0 bg-amber-900/30"></div>

    <div class="relative z-10 px-4 max-w-2xl mx-auto w-full">

      <h1 class="hero-slide text-5xl font-bold italic mb-4 text-amber-100 drop-shadow-lg">
        Kontakt
      </h1>

      <p class="hero-slide text-xl text-amber-100 drop-shadow-md mb-10">
        -- Skicka en bokningsförfråga för offert --
      </p>

      <form class="space-y-6 bg-amber-900/40 backdrop-blur-md p-8 rounded-xl shadow-lg text-black">

        <div class="grid md:grid-cols-2 gap-6">
          <input
            type="text"
            name="name"
            placeholder="Namn"
            required
            class="p-3 border rounded-lg w-full"
          />

          <input
            type="email"
            name="email"
            placeholder="Email"
            required
            class="p-3 border rounded-lg w-full"
          />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <select name="eventType" class="p-3 border rounded-lg w-full">
            <option value="">Typ av event</option>
            <option>Bar / Restaurant</option>
            <option>Firmafest</option>
            <option>Privatfest</option>
            <option>Annat</option>
          </select>

          <input
            type="text"
            name="location"
            placeholder="Plats"
            class="p-3 border rounded-lg w-full"
          />
        </div>

        <div>
          <input
            type="date"
            name="date"
            class="p-3 border rounded-lg w-full"
          />
        </div>

        <textarea 
          name="message"
          rows="5"
          placeholder="Övrig information"
          class="p-3 border rounded-lg w-full"
        ></textarea>

        <button
          type="submit"
          class=" bg-amber-700 hover:bg-amber-600 text-white py-3 px-6 rounded-lg font-semibold transition"
        > 
          Skicka förfrågan
        </button>

      </form>

    </div>
  </section>

</Layout>